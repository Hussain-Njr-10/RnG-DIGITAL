---
import PortalApp from '@/components/portal/PortalApp'
import '@/styles/global.scss'

export function getStaticPaths() {
  return [
    { params: { all: undefined } } // Pre-render the shell for /portal/, Netlify redirects handle the rest
  ];
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Portal Dashboard</title>
  </head>
  <body>
    <!-- The client:only directive ensures this is entirely client-side rendered -->
    <PortalApp client:only="react" />
  </body>
</html>
