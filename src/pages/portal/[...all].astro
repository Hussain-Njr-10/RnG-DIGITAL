---
import PortalApp from '@/components/portal/PortalApp'
import '@/styles/global.scss'

export function getStaticPaths() {
  return [
    { params: { all: undefined } }, // handles /portal/
    { params: { all: 'login' } },
    { params: { all: 'set-password' } },
    { params: { all: 'admin' } },
    { params: { all: 'admin/settings' } },
    { params: { all: 'client' } },
    { params: { all: 'client/reports' } },
    { params: { all: 'staff' } },
    { params: { all: 'staff/tasks' } }
  ];
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Portal Dashboard</title>
  </head>
  <body>
    <!-- The client:only directive ensures this is entirely client-side rendered -->
    <PortalApp client:only="react" />
  </body>
</html>
